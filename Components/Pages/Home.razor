@page "/"
@rendermode InteractiveServer
@using MantelProgrammingTest.Services
@inject ILogFileService LogFileService

<PageTitle>Home</PageTitle>

<h1>Mantel Programming Test</h1>
<p class="author">by Indo Ty</p>

<div class="format-info">
    <div class="format-info-header">
        <span class="format-info-icon">📋</span>
        <h3>Upload an HTTP access log in the Combined Log Format</h3>
    </div>
    <p class="format-info-description">The log file should contain entries in the following format:</p>
    <div class="format-sample">
        <span class="token ip">IP Address</span>
        <span class="token dim">-</span>
        <span class="token identity">identity</span>
        <span class="token timestamp">[timestamp]</span>
        <span class="token method">"method URL protocol"</span>
        <span class="token status">status</span>
        <span class="token size">size</span>
        <span class="token referer">"referer"</span>
        <span class="token useragent">"user-agent"</span>
    </div>
</div>

<div class="upload-area @dropClass"
     @ondragenter="HandleDragEnter"
     @ondragleave="HandleDragLeave"
     @ondragover="HandleDragEnter"
     @ondragover:preventDefault>

    <InputFile OnChange="HandleFileUpload" accept=".log" class="upload-drop-zone" />

    <div class="upload-icon">📄</div>
    <p class="upload-prompt">Drag &amp; drop a log file here, or</p>
    <label class="upload-button">
        Browse Files
        <InputFile OnChange="HandleFileUpload" accept=".log" />
    </label>
</div>

@if (uploadedFileName is not null)
{
    <div class="upload-result @(isError ? "upload-error" : "upload-success")">
        <span class="upload-result-icon">@(isError ? "⚠️" : "✅")</span>
        <span>@statusMessage</span>
    </div>
}

@if (validationErrors.Count > 0)
{
    <div class="upload-result upload-error">
        <div>
            <span class="upload-result-icon">⚠️</span>
            <strong>The file is not in the expected Combined Log Format.</strong>
            <ul style="margin-top: 0.5rem; margin-bottom: 0;">
                @foreach (var error in validationErrors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    </div>
}

@if (interrogationResult is not null)
{
    <div class="analysis-section">
        <h2 class="analysis-title">📊 Log File Analysis</h2>

        <div class="analysis-grid">
            <div class="analysis-card highlight-card">
                <div class="analysis-card-icon">🌐</div>
                <div class="analysis-card-value">@interrogationResult.UniqueIpAddressCount</div>
                <div class="analysis-card-label">Unique IP Addresses</div>
            </div>

            <div class="analysis-card">
                <div class="analysis-card-header">
                    <span class="analysis-card-icon">🔗</span>
                    <h3>Top 3 Most Visited URLs</h3>
                </div>
                <ol class="analysis-list">
                    @foreach (var url in interrogationResult.TopVisitedUrls)
                    {
                        <li>
                            <span class="analysis-item-label">@url.Url</span>
                            <span class="analysis-badge">@url.VisitCount visits</span>
                        </li>
                    }
                </ol>
            </div>

            <div class="analysis-card">
                <div class="analysis-card-header">
                    <span class="analysis-card-icon">📡</span>
                    <h3>Top 3 Most Active IP Addresses</h3>
                </div>
                <ol class="analysis-list">
                    @foreach (var ip in interrogationResult.TopActiveIpAddresses)
                    {
                        <li>
                            <span class="analysis-item-label">@ip.IpAddress</span>
                            <span class="analysis-badge">@ip.RequestCount requests</span>
                        </li>
                    }
                </ol>
            </div>
        </div>
    </div>
}

@code {
    private const long MaxFileSize = 10 * 1024 * 1024;

    private string? statusMessage;
    private string? uploadedFileName;
    private bool isError;
    private string dropClass = string.Empty;
    private List<string> validationErrors = [];
    private LogInterrogationResult? interrogationResult;

    private void HandleDragEnter() => dropClass = "drag-over";
    private void HandleDragLeave() => dropClass = string.Empty;

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        dropClass = string.Empty;
        validationErrors = [];
        interrogationResult = null;
        var file = e.File;

        if (file is null)
        {
            isError = true;
            uploadedFileName = "none";
            statusMessage = "No file selected.";
            return;
        }

        try
        {
            // Read file content into memory for validation
            using var memoryStream = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: MaxFileSize).CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            using var reader = new StreamReader(memoryStream);
            var content = await reader.ReadToEndAsync();

            // Validate using LogFileService
            var result = LogFileService.Validate(content);

            if (!result.IsValid)
            {
                isError = true;
                uploadedFileName = file.Name;

                if (result.ErrorMessage is not null)
                {
                    statusMessage = result.ErrorMessage;
                    return;
                }

                statusMessage = $"Validation failed for \"{file.Name}\".";

                // Show up to 5 invalid lines to avoid flooding the UI
                foreach (var (lineNumber, line) in result.InvalidLines.Take(5))
                {
                    var preview = line.Length > 80 ? line[..80] + "…" : line;
                    validationErrors.Add($"Line {lineNumber}: {preview}");
                }

                if (result.InvalidLines.Count > 5)
                {
                    validationErrors.Add($"...and {result.InvalidLines.Count - 5} more invalid line(s).");
                }

                return;
            }

            // Interrogate the log file for analysis
            interrogationResult = LogFileService.InterrogateLogFile(content);

            isError = false;
            uploadedFileName = file.Name;
            statusMessage = $"Uploaded \"{file.Name}\" ({file.Size:N0} bytes)";
        }
        catch (IOException)
        {
            isError = true;
            uploadedFileName = file.Name;
            statusMessage = $"File \"{file.Name}\" exceeds the maximum allowed size of {MaxFileSize / (1024 * 1024)} MB.";
        }
        catch (Exception ex)
        {
            isError = true;
            uploadedFileName = file.Name;
            statusMessage = $"Upload failed: {ex.Message}";
        }
    }
}
